# EmotionAI Frontend Environment Variables
# Copy this to .env and edit as needed

# Set to "true" to use the Python FastAPI backend for inference
# Default "false" uses face-api.js directly in the browser (no backend needed)
VITE_USE_BACKEND=false

# Backend API base URL (only used when VITE_USE_BACKEND=true)
VITE_API_URL=http://localhost:8000
